{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 ~/.codex/hooks/session_start.py",
          "timeout": 30,
          "statusMessage": "Loading session notes"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "^Bash$",
      "hooks": [
        {
          "type": "command",
          "command": "./scripts/lint.sh"
        }
      ]
    }
  ]
}
